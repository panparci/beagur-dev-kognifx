API_IMAGE=ghcr.io/your-github-user/bea-guru/api:latest
AUTH_IMAGE=ghcr.io/your-github-user/bea-guru/auth:latest
WEB_IMAGE=ghcr.io/your-github-user/bea-guru/web:latest

WEB_PORT=80
POSTGRES_DB=bea_guru
POSTGRES_USER=bea_guru_app
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://bea_guru_app:change-me@postgres:5432/bea_guru?sslmode=disable

FRONTEND_URL=https://your-domain.com
ALLOWED_ORIGINS=https://your-domain.com
BETTER_AUTH_URL=https://your-domain.com
BETTER_AUTH_JWKS_URL=http://auth:3001/api/auth/jwks
BETTER_AUTH_SECRET=change-me-min-32-chars

OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=https://your-domain.com
AI_MODELS=qwen/qwen3-coder:free,nvidia/nemotron-3-super-120b-a12b:free,openai/gpt-oss-120b:free,openai/gpt-oss-20b:free,qwen/qwen3-next-80b-a3b-instruct:free,nvidia/nemotron-3-nano-30b-a3b:free,meta-llama/llama-3.3-70b-instruct:free,nousresearch/hermes-3-llama-3.1-405b:free,cohere/north-mini-code:free,openrouter/free
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

BREVO_API_KEY=
EMAIL_FROM=
EMAIL_FROM_NAME=Bea Guru

INTERNAL_NOTIFY_SECRET=
API_INTERNAL_URL=http://api:8080
UPLOAD_DIR=/app/uploads
LOG_LEVEL=info

# Cloudflare R2 — foto guru & laporan (wajib prod agar DB tidak simpan base64)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=bea-guru-media
R2_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev
