# Better Auth (auth server + client)
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000
AUTH_SERVER_PORT=3001
FRONTEND_URL=http://localhost:3000

# Same PostgreSQL as Go backend
DATABASE_URL=postgres://bea_guru_app:YOUR_PASSWORD@localhost:5432/bea_guru?sslmode=disable

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Set same value as GOOGLE_CLIENT_ID to show Google button on login page
VITE_GOOGLE_CLIENT_ID=
