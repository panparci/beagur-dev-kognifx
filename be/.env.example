APP_ENV=development
APP_NAME=bea-guru-api
PORT=8080
LOG_LEVEL=info
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# Production: set APP_ENV=production to disable dev-login, X-User-* header auth, and legacy email-only login.
# Better Auth JWT validation (required when FE uses Bearer tokens):
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_JWKS_URL=http://localhost:3001/api/auth/jwks

# PostgreSQL VPS connection string.
# Example: postgres://user:password@host:5432/bea_guru?sslmode=require
DATABASE_URL=

# Optional — enables live OpenRouter responses; without it, offline fallbacks are used.
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=http://localhost:3000
AI_MODELS=qwen/qwen3-coder:free,nvidia/nemotron-3-super-120b-a12b:free,openai/gpt-oss-120b:free,openai/gpt-oss-20b:free,qwen/qwen3-next-80b-a3b-instruct:free,nvidia/nemotron-3-nano-30b-a3b:free,meta-llama/llama-3.3-70b-instruct:free,nousresearch/hermes-3-llama-3.1-405b:free,cohere/north-mini-code:free,openrouter/free

READ_HEADER_TIMEOUT=5s
READ_TIMEOUT=15s
WRITE_TIMEOUT=15s
IDLE_TIMEOUT=60s

# Email notifications (Brevo — free tier 300 emails/day)
# Sign up: https://www.brevo.com — verify sender domain/email in dashboard first.
BREVO_API_KEY=
EMAIL_FROM=
EMAIL_FROM_NAME=Bea Guru
FRONTEND_URL=http://localhost:3000

# Shared secret for auth server → API signup notifications (set same in fe/.env)
INTERNAL_NOTIFY_SECRET=
